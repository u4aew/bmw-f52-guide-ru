  <!-- ═══ YANDEX MAPS ═══ -->
  <script is:inline>
    // Coords: [longitude, latitude] — ymaps3 v3 format
    var YMAP_CITIES = [
      { name: 'Москва',           coords: [37.6173, 55.7558] },
      { name: 'Санкт-Петербург',  coords: [30.3158, 59.9390] },
      { name: 'Сочи',             coords: [39.7257, 43.5855] },
      { name: 'Новосибирск',      coords: [82.9057, 54.9893] },
      { name: 'Барнаул',          coords: [83.7697, 53.3548] },
      { name: 'Бийск',            coords: [85.9602, 52.5390] },
      { name: 'Екатеринбург',     coords: [60.6057, 56.8389] },
      { name: 'Казань',           coords: [49.1064, 55.7961] },
      { name: 'Тюмень',           coords: [68.9585, 57.1530] },
      { name: 'Пермь',            coords: [56.2502, 58.0105] },
      { name: 'Красноярск',       coords: [92.8725, 56.0097] },
      { name: 'Иркутск',          coords: [104.2964, 52.2978] },
      { name: 'Иваново',          coords: [41.0082, 57.0005] },
      { name: 'Уфа',              coords: [55.9721, 54.7388] },
      { name: 'Рязань',           coords: [39.7006, 54.6269] },
      { name: 'Великий Новгород', coords: [31.2737, 58.5226] },
      { name: 'Краснодар',        coords: [38.9754, 45.0360] },
      { name: 'Мурманск',         coords: [33.0856, 68.9585] },
      { name: 'Севастополь',      coords: [33.5254, 44.6167] },
      { name: 'Ростов-на-Дону',   coords: [39.7188, 47.2225] },
      { name: 'Челябинск',        coords: [61.3673, 55.1644] },
      { name: 'Нижний Новгород',  coords: [44.0060, 56.3269] },
      { name: 'Волгоград',        coords: [44.5133, 48.7080] },
      { name: 'Калининград',      coords: [20.4522, 54.7104] },
      { name: 'Оренбург',         coords: [55.1003, 51.7727] },
      { name: 'Хабаровск',        coords: [135.0837, 48.4827] },
      { name: 'Серпухов',         coords: [37.4147, 54.9153] },
      { name: 'Сыктывкар',        coords: [50.8366, 61.6688] },
      { name: 'Сургут',           coords: [73.4018, 61.2540] },
      { name: 'Липецк',           coords: [39.5975, 52.6031] },
      { name: 'Тверь',            coords: [35.9006, 56.8587] },
      { name: 'Омск',             coords: [73.3645, 54.9914] },
    ];

    async function initYMap() {
      if (!document.getElementById('ymap')) return;
      await ymaps3.ready;

      var YMap                 = ymaps3.YMap;
      var YMapDefaultSchemeLayer   = ymaps3.YMapDefaultSchemeLayer;
      var YMapDefaultFeaturesLayer = ymaps3.YMapDefaultFeaturesLayer;
      var YMapMarker           = ymaps3.YMapMarker;

      var map = new YMap(
        document.getElementById('ymap'),
        {
          location: { center: [65.0, 58.0], zoom: 3 },
        }
      );

      map.addChild(new YMapDefaultSchemeLayer({}));
      map.addChild(new YMapDefaultFeaturesLayer({}));

      var activePopup = null;

      document.addEventListener('click', function() {
        if (activePopup) { map.removeChild(activePopup); activePopup = null; }
      });

      YMAP_CITIES.forEach(function(city) {
        // ── Dot ──
        var dot = document.createElement('div');
        dot.style.cssText = 'width:12px;height:12px;background:#1d4ed8;border:2.5px solid #fff;border-radius:50%;box-shadow:0 1px 5px rgba(0,0,0,0.3);cursor:pointer;transition:transform 0.15s;';
        dot.addEventListener('mouseenter', function() { dot.style.transform = 'scale(1.5)'; });
        dot.addEventListener('mouseleave', function() { dot.style.transform = 'scale(1)'; });

        // ── Balloon element (lives in map coords via YMapMarker) ──
        var balloonEl = document.createElement('div');
        balloonEl.style.cssText = 'display:inline-block;cursor:default;';

        var bubble = document.createElement('div');
        bubble.textContent = city.name;
        bubble.style.cssText = [
          'background:#fff',
          'border:1px solid rgba(0,0,0,0.08)',
          'border-radius:10px',
          'padding:7px 14px',
          'font-size:13px',
          'font-weight:600',
          'color:#1e293b',
          'white-space:nowrap',
          'box-shadow:0 6px 20px rgba(0,0,0,0.12),0 2px 6px rgba(0,0,0,0.06)',
          'font-family:inherit',
        ].join(';');

        var arrow = document.createElement('div');
        arrow.style.cssText = [
          'width:0',
          'height:0',
          'border-left:7px solid transparent',
          'border-right:7px solid transparent',
          'border-top:7px solid #fff',
          'margin:0 auto',
          'filter:drop-shadow(0 2px 2px rgba(0,0,0,0.06))',
        ].join(';');

        balloonEl.appendChild(bubble);
        balloonEl.appendChild(arrow);

        // anchor [0.5, 1] — bottom-center of element is at the coordinate point
        var popupMarker = new YMapMarker({ coordinates: city.coords, anchor: [0.5, 1] }, balloonEl);

        dot.addEventListener('click', function(e) {
          e.stopPropagation();
          if (activePopup === popupMarker) {
            map.removeChild(activePopup);
            activePopup = null;
            return;
          }
          if (activePopup) map.removeChild(activePopup);
          map.addChild(popupMarker);
          activePopup = popupMarker;
        });

        map.addChild(new YMapMarker({ coordinates: city.coords, anchor: [0.5, 0.5] }, dot));
      });
    }

    initYMap();
  </script>

