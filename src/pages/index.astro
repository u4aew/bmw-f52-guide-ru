          </div>
          <div>
            <div class="seo-fact-label">Трансмиссия</div>
            <div class="seo-fact-value">6AT / 8AT (Aisin), 7DCT</div>
          </div>
          <div>
            <div class="seo-fact-label">Код кузова</div>
            <div class="seo-fact-value">F52</div>
