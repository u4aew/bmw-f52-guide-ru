          quality={85}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>

      <!-- SEO text + facts -->
      <div class="seo-section anim anim-4">
        <div class="seo-main">
          <h2>Что такое BMW F52</h2>
          <p>
            BMW F52 — четырёхдверный компактный седан, выпускавшийся с 2017 по 2023 год.
            Модель была разработана на совместном предприятии BMW Brilliance в Шэньяне
            изначально для китайского рынка, но позже официально продавалась и в Мексике.
            В отличие от классических европейских хэтчбеков 1-й серии тех лет, F52 получил
            кузов седан, увеличенную колёсную базу и просторный багажник.
          </p>
          <p>
            Автомобиль построен на модульной переднеприводной платформе BMW UKL2 с поперечным
            расположением двигателя — той же, что лежит в основе MINI Countryman (F60),
            BMW X1 (F48) и BMW X2 (F39).
          </p>
          <p>
            Линейка двигателей включает трёхцилиндровый турбомотор B38 объёмом 1,5 л и
            четырёхцилиндровый B48 объёмом 2,0 л. В зависимости от года выпуска и мотора,
            автомобили оснащались 6- или 8-ступенчатым автоматом Aisin, а после рестайлинга —
            7-ступенчатым «роботом» с двойным сцеплением (7DCT).
          </p>
